{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Hosting": {
    "CustomerDashboardBaseUrl": "http://localhost:5173"
  },
  "ConnectionStrings": {
    "Orchestrator": "Host=localhost;Port=5432;Database=shipping_orchestrator;Username=app;Password=app_dev_password",
    "OperationsRead": "Host=localhost;Port=5432;Database=shipping_orchestrator;Username=app;Password=app_dev_password"
    // Optional: when present, PrivateApi binds OperationsReadDbContext to this replica instead of OperationsRead.
    // "OperationsReadReplica": "Host=ops-read-replica.local;Port=5432;Database=shipping_orchestrator;Username=ops_read;Password=***"
  },
  "Encryption": {
    "Aes": {
      "Base64Key": "REPLACE_WITH_BASE64_OF_32_BYTES_FOR_LOCAL_DEV_ONLY_AAAA="
    }
  },
  "Connectors": {
    "Shopify": {
      "ClientId": "shopify-client-id-placeholder",
      "ClientSecret": "shopify-client-secret-placeholder"
    },
    "WooCommerce": {
      "AppName": "Ship Shipping",
      "Scope": "read_write"
    },
    "PostNL": {
      "InMemory": {
        "MinLatencyMs": 100,
        "MaxLatencyMs": 500,
        "FailureProbability": 0.0
      }
    }
  }
}
