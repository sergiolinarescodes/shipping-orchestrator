{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Orchestrator": "Host=localhost;Port=5432;Database=shipping_orchestrator;Username=app;Password=app_dev_password",
    "CustomerRead": "Host=localhost;Port=5432;Database=shipping_orchestrator;Username=app;Password=app_dev_password"
    // Optional: when present, PublicApi binds CustomerReadDbContext to this replica instead of CustomerRead.
    // "CustomerReadReplica": "Host=customer-read-replica.local;Port=5432;Database=shipping_orchestrator;Username=customer_read;Password=***"
  },
  "Encryption": {
    "Aes": {
      "Base64Key": "REPLACE_WITH_BASE64_OF_32_BYTES_FOR_LOCAL_DEV_ONLY_AAAA="
    }
  },
  "Auth": {
    "VerifyEndpointBaseUrl": "http://localhost:5101",
    "DashboardBaseUrl": "http://localhost:5173",
    "MagicLinkTtlSeconds": 900,
    "SessionTtlSeconds": 2592000,
    "FromAddress": "no-reply@shipping-orchestrator.local",
    "FromDisplayName": "Shipping Orchestrator",
    "CookieName": "so.session"
  },
  "Email": {
    "Smtp": {
      "Host": "localhost",
      "Port": 1025,
      "UseStartTls": false,
      "FromAddress": "no-reply@shipping-orchestrator.local",
      "FromDisplayName": "Shipping Orchestrator"
    }
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": "http://localhost:4317"
    }
  },
  "Connectors": {
    "Shopify": {
      "ClientId": "shopify-client-id-placeholder",
      "ClientSecret": "shopify-client-secret-placeholder",
      "Scopes": "read_orders,write_fulfillments"
    },
    "WooCommerce": {
      "AppName": "Ship Shipping",
      "Scope": "read_write",
      "ReturnUrl": "http://localhost:5173/connections?wc=connected",
      "CallbackBaseUrl": "http://localhost:5101",
      "OrchestratorWebhookUrl": "http://host.docker.internal:5101/v1/webhooks/woocommerce"
    },
    "PostNL": {
      "InMemory": {
        "MinLatencyMs": 200,
        "MaxLatencyMs": 1500,
        "FailureProbability": 0.0,
        "LabelStorageBaseUri": "https://mock.postnl.local/labels"
      }
    }
  }
}
